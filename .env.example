# BrutalAudit Environment Variables
# Copy this file to .env.local and fill in the values

# Next.js URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Supabase (Database)
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Firebase (Authentication)
NEXT_PUBLIC_FIREBASE_API_KEY="your-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project-id.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
NEXT_PUBLIC_FIREBASE_APP_ID="your-app-id"
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="your-measurement-id"

# Groq (AI Models)
GROQ_API_KEY="your-groq-api-key"

# GitHub App/OAuth (Optional for higher rate limits)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Developer Portal Admin (REQUIRED — server-side only, never expose to client)
# Set these in Vercel Dashboard → Settings → Environment Variables
DEV_ADMIN_EMAIL="your-admin-email@example.com"
DEV_ADMIN_PASS="your-very-strong-password-here"
